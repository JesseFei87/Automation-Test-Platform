      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "runner.main",
        "run-case",
        "TC-ICM-009"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
