{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ICM Platform: Start Backend API",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "icm_platform.api:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "ICM Platform: Start Frontend UI",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "npm run dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/web-ui"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "ICM Platform: Setup Trace Viewer HTTPS",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/setup_trace_viewer_https.py",
        "--host",
        "${input:traceViewerHost}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ICM Platform: Start Trace Viewer HTTPS",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "icm_platform.api:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8443",
        "--ssl-keyfile",
        "platform-data/tls/qa-platform-server.key",
        "--ssl-certfile",
        "platform-data/tls/qa-platform-server.crt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ICM: Run Single Case",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "runner.main",
        "run-case",
        "${input:icmCaseId}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "ICM: Run Chain 006-011",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "runner.main",
        "run-case",
        "TC-ICM-006"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "dependsOrder": "sequence",
      "dependsOn": [
        "ICM: Run Case 007",
        "ICM: Run Case 008",
        "ICM: Run Case 009",
        "ICM: Run Case 010",
        "ICM: Run Case 011"
      ]
    },
    {
      "label": "ICM: Run Case 007",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "runner.main",
        "run-case",
        "TC-ICM-007"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
