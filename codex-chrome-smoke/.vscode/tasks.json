    {
      "label": "ICM: Run Batch 001-012",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "runner.main",
        "run-batch",
        "${input:icmBatchRunId}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "traceViewerHost",
      "type": "promptString",
      "description": "Remote IP address or DNS name of this QA Platform server",
      "default": "192.168.66.175"
    },
    {
      "id": "icmCaseId",
      "type": "pickString",
      "description": "Choose the ICM case to run",
      "options": [
        "TC-ICM-001",
        "TC-ICM-002",
        "TC-ICM-003",
        "TC-ICM-004",
        "TC-ICM-005",
        "TC-ICM-006",
        "TC-ICM-007",
        "TC-ICM-008",
        "TC-ICM-009",
        "TC-ICM-010",
        "TC-ICM-011",
        "TC-ICM-012"
      ],
      "default": "TC-ICM-001"
    },
    {
      "id": "icmBatchRunId",
      "type": "promptString",
      "description": "Enter the batch run id, for example 20260601-local-batch-01",
      "default": "20260601-local-batch-01"
    }
  ]
}
