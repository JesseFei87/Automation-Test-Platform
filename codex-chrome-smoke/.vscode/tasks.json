      },
      "problemMatcher": []
    },
    {
      "label": "ICM: Run Case 010",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "runner.main",
        "run-case",
        "TC-ICM-010"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
