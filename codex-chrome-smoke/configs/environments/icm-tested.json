{
  "id": "icm-tested",
  "name": "ICM tested system",
  "element_knowledge_scan_enabled": true,
  "auth_mode": "cdp_attach",
  "cdp_endpoint": "http://127.0.0.1:9222",
  "auto_discover_routes": true,
  "route_discovery_max_actions": 24,
  "route_discovery_max_pages": 20,
  "state_scan_max_states": 8,
  "state_scan_max_per_kind": 2,
  "base_url": "https://192.168.16.203:49187",
  "headless": false,
  "storage_state": "platform-data/auth/icm-tested-admin.json",
  "login": {
    "url": "https://192.168.16.203:49187/#/login?redirect=%2Fredirect",
    "username": "admin",
    "password": "[ENV:ICM_ADMIN_PASSWORD]",
    "username_selector": "form input[type=\"text\"]",
    "password_selector": "form input[type=\"password\"]",
    "submit_selector": "form button.el-button--primary",
    "check_url": "https://192.168.16.203:49187/#/index",
    "success_url_contains": "#/index"
  },
  "verified_menu_routes": [
