  3) 在真实环境跑一次：python -m runner.main run-case {{ case_id }} <run_id>
"""
from __future__ import annotations

import re
from typing import Any

from playwright.async_api import Page

from runner.browser import (
    click_first,
    click_text,
    ensure_text_visible,
    fill_first,
    open_device_list,
    open_homepage,
    open_remote_help,
    open_server_list,
    open_user_management,
)
from runner.flows.icm_common import (
    click_dialog_primary,
    ensure_fresh_login,
    ensure_switch_enabled,
    prepare_session,
    search_by_keyword,
    settle,
    wait_for_table_row,
    wait_for_visible_dialog,
)


# 打开 / 跳转类步骤的路由名派发表（按子串匹配）
_OPEN_ROUTE_DISPATCH: tuple[tuple[re.Pattern[str], str], ...] = (
    (re.compile(r"device|设备"), "open_device_list"),
    (re.compile(r"server|服务器"), "open_server_list"),
    (re.compile(r"user|用户"), "open_user_management"),
    (re.compile(r"remote|远程|help|帮助"), "open_remote_help"),
    (re.compile(r"home|首页|主页"), "open_homepage"),
)


# 默认 selector / input_value 候选（按常见用例命名约定）
_QUERY_SELECTOR_KEYS = ("device_query_input", "search_input", "query_input", "device_search_input")
_SEARCH_BUTTON_KEYS = ("search_button", "add_button", "confirm_button", "submit_button")
_QUERY_VALUE_KEYS = ("device_keyword", "keyword", "query", "search_value")


def _pick_first_selectors(selectors: dict[str, Any], keys: tuple[str, ...]) -> list[str]:
    for key in keys:
        value = selectors.get(key)
        if isinstance(value, list) and value:
            return [str(v) for v in value]
        if isinstance(value, str) and value:
            return [value]
    return []


def _pick_first_value(input_values: dict[str, Any], keys: tuple[str, ...]) -> str:
    for key in keys:
        if key in input_values and input_values[key] is not None:
            return str(input_values[key])
    return ""


async def _dispatch_step(
    page: Page,
    system: dict[str, Any],
    step: str,
    selectors: dict[str, Any],
    input_values: dict[str, Any],
) -> None:
    text = (step or "").strip()
    if not text:
        return
    lower = text.lower()

    # 1) 登录 / 会话
    if re.search(r"登录|prepare|已登录|确保登录|login", lower):
        await prepare_session(page, system)
        return

    # 2) 打开 / 跳转
    if re.search(r"打开|open|navigate|访问|进入|跳到|跳至", lower):
        for pattern, name in _OPEN_ROUTE_DISPATCH:
            if pattern.search(lower):
                fn = globals().get(name)
                if fn is not None:
                    await fn(page, system)
                    return
        # 默认走设备列表（最常见入口）
        await open_device_list(page, system)
        return

    # 3) 搜索 / 查询
    if re.search(r"搜索|查询|query|keyword|关键字", lower):
        sel = _pick_first_selectors(selectors, _QUERY_SELECTOR_KEYS)
        kw = _pick_first_value(input_values, _QUERY_VALUE_KEYS)
        if sel and kw:
            await search_by_keyword(page, sel, kw)
        return

    # 4) 输入 / 填写
    if re.search(r"输入|填写|fill|enter|键入", lower):
        sel = _pick_first_selectors(selectors, _QUERY_SELECTOR_KEYS)
        kw = _pick_first_value(input_values, _QUERY_VALUE_KEYS)
        if sel and kw:
            await fill_first(page, sel, kw)
        return

    # 5) 点击
    if re.search(r"点击|click|按下|触发|submit|提交", lower):
        sel = _pick_first_selectors(selectors, _SEARCH_BUTTON_KEYS)
        if sel:
            await click_first(page, sel)
        return

    # 6) 断言 / 验证
    if re.search(r"断言|assert|verify|确认|验证|可见", lower):
        kw = _pick_first_value(input_values, _QUERY_VALUE_KEYS)
        if kw:
            await ensure_text_visible(page, kw)
        return

    # 7) 等待 / settle
    if re.search(r"settle|等待|wait", lower):
        await settle(page, 300)
        return

    # 默认落 settle，避免 break pipeline（人工会再调整）
    await settle(page, 300)


async def run(page: Page, system: dict[str, Any], case: dict[str, Any]) -> None:
    """按 operation_steps 顺序派发到工具函数（架构 §2 C2 关键词派发）。"""
    asset = case.get("automation_asset", {}) or {}
    operation_steps: list[str] = [str(s) for s in (asset.get("operation_steps") or [])]
    selectors: dict[str, Any] = dict(asset.get("selectors") or {})
    input_values: dict[str, Any] = dict(asset.get("input_values") or {})

    await prepare_session(page, system)
    for step in operation_steps:
        await _dispatch_step(page, system, step, selectors, input_values)
